# Copy this file to .env.production and replace every placeholder before deploying.

POSTGRES_DB=storyforge
POSTGRES_USER=storyforge
POSTGRES_PASSWORD=change-this-postgres-password

REDIS_PASSWORD=change-this-redis-password
SESSION_SECRET=change-this-session-secret

APP_ENV=production
EXPOSE_API_DOCS=false
SECURE_COOKIES=true

FRONTEND_BASE_URL=https://storyforge.example.com
NEXT_PUBLIC_API_BASE_URL=https://storyforge.example.com/api/v1
NEXT_PUBLIC_APP_NAME=Story Forge

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://storyforge.example.com/api/v1/auth/spotify/callback

# Use JSON arrays for these settings.
ALLOWED_HOSTS=["storyforge.example.com","www.storyforge.example.com"]
CORS_ALLOWED_ORIGINS=["https://storyforge.example.com","https://www.storyforge.example.com"]

# Leave blank in production unless you explicitly need a regex-based CORS rule.
CORS_ALLOWED_ORIGIN_REGEX=

SOURCE_RETENTION_HOURS=24
IMAGE_GENERATOR_MODE=mock
MUSIC_SELECTOR_MODE=mock
